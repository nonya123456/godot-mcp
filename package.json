{
  "name": "godot-mcp",
  "version": "0.1.1",
  "description": "MCP server for interfacing with Godot game engine. Provides tools for launching the editor, running projects, and capturing debug output.",
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "claude",
    "cline"
  ],
  "homepage": "https://github.com/nonya123456/godot-mcp#readme",
  "bugs": {
    "url": "https://github.com/nonya123456/godot-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonya123456/godot-mcp.git"
  },
  "license": "MIT",
  "author": "Solomon Elias <solomon@sippy.ai>",
  "type": "module",
  "bin": {
    "godot-mcp": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "inspector": "bunx @modelcontextprotocol/inspector bun run src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
